    "# ── CELL 6: Player SOT calculator ─────────────────────────────────────────────\n",
    "\n",
    "def player_sot(\n",
    "    name: str,\n",
    "    shots_per_90: float,\n",
    "    sot_accuracy: float,\n",
    "    expected_minutes: float,\n",
    "    role_discount: float = 1.0,\n",
    "    context_factor: float = 1.0\n",
    ") -> float:\n",
    "    \"\"\"\n",
    "    P(player gets ≥1 SOT) via Poisson.\n",
    "\n",
    "    role_discount cheat sheet:\n",
    "      0.40  pure DM (Sangaré, Xhaka deep, Tielemans holding)\n",
    "      0.55  box-to-box in double pivot (Kökçü today)\n",
    "      0.70  wide midfielder / 8\n",
    "      0.85  attacking mid / 10\n",
    "      1.00  central striker / wide attacker\n",
    "      1.15  penalty taker + set piece + sole creator (Enciso)\n",
    "\n",
    "    context_factor:\n",
    "      0.65  very cagey (both teams draw is enough)\n",
    "      0.80  cautious\n",
    "      1.00  neutral\n",
    "      1.15  open / both teams attack\n",
    "      1.30  high tempo, must-win mismatch\n",
    "    \"\"\"\n",
    "    lam = shots_per_90 * sot_accuracy * (expected_minutes/90) * role_discount * context_factor\n",
    "    prob = 1 - np.exp(-lam)\n",
    "    print(f'  {name:25s} | λ={lam:.3f} | P(≥1 SOT) = {prob:.1%}')\n",
    "    return prob\n",
    "\n",
    "# ── Calibration corrections from your RBP history ────────────────────────────\n",
    "CALIBRATION = {\n",
    "    'penalty_red':           0.72,  # crowds say 35-40%, truth is 22-26%\n",
    "    'btts_over25':           0.88,  # slight underprice in competitive games\n",
    "    '2h_more_goals':         0.87,  # crowds overestimate 2H chaos\n",
    "    'dm_sot':                0.45,  # deep midfielder SOT: systematic crowd overpricing\n",
    "    'chasing_offsides':      1.15,  # chasing teams run behind more than model captures\n",
    "    'big_fav_corners':       1.10,  # dominant teams win corner battle more than expected\n",
    "    'underdog_score':        0.90,  # slight underdog score underpricing (Ecuador lesson)\n",
    "}\n",
    "\n",
    "def calibrate(raw: float, prop_type: str) -> float:\n",
    "    c = np.clip(raw * CALIBRATION.get(prop_type, 1.0), 0.05, 0.95)\n",
    "    print(f'  {prop_type}: {raw:.1%} → {c:.1%} (×{CALIBRATION.get(prop_type,1.0)})')\n",
    "    return c\n",
    "\n",
    "print('✅ Player SOT + calibration ready.')"
   ]
