    "# ── CELL 3: Build team attack/defense profiles from historical data ────────────\n",
    "\n",
    "# Combine home and away records for each team\n",
    "home = wc[['home_team', 'home_score', 'away_score']].rename(\n",
    "    columns={'home_team': 'team', 'home_score': 'scored', 'away_score': 'conceded'})\n",
    "away = wc[['away_team', 'away_score', 'home_score']].rename(\n",
    "    columns={'away_team': 'team', 'away_score': 'scored', 'home_score': 'conceded'})\n",
    "\n",
    "all_records = pd.concat([home, away])\n",
    "\n",
    "# League average (for Dixon-Coles style attack/defense ratings)\n",
    "LEAGUE_AVG_GOALS = all_records['scored'].mean()\n",
    "\n",
    "team_stats = all_records.groupby('team').agg(\n",
    "    avg_scored=('scored', 'mean'),\n",
    "    avg_conceded=('conceded', 'mean'),\n",
    "    n_matches=('scored', 'count')\n",
    ").reset_index()\n",
    "\n",
    "# Attack/defense ratings relative to league average\n",
    "# attack > 1 = scores more than average, defense < 1 = concedes less than average\n",
    "team_stats['attack']  = team_stats['avg_scored']   / LEAGUE_AVG_GOALS\n",
    "team_stats['defense'] = team_stats['avg_conceded']  / LEAGUE_AVG_GOALS\n",
    "\n",
    "def get_team_profile(team_name: str) -> dict:\n",
    "    \"\"\"\n",
    "    Get historical WC attack/defense rating for a team.\n",
    "    Falls back to league average (1.0) if fewer than 3 matches.\n",
    "    \"\"\"\n",
    "    row = team_stats[team_stats['team'] == team_name]\n",
    "    if len(row) == 0 or row.iloc[0]['n_matches'] < 3:\n",
    "        return {'attack': 1.0, 'defense': 1.0, 'n': 0, 'note': 'insufficient data'}\n",
    "    r = row.iloc[0]\n",
    "    return {\n",
    "        'attack':  round(r['attack'],  3),\n",
    "        'defense': round(r['defense'], 3),\n",
    "        'n':       int(r['n_matches']),\n",
    "        'avg_scored':   round(r['avg_scored'],   2),\n",
    "        'avg_conceded': round(r['avg_conceded'],  2)\n",
    "    }\n",
    "\n",
    "# Quick sanity check\n",
    "for t in ['Brazil', 'Germany', 'Paraguay', 'Australia', 'Turkey', 'United States']:\n",
    "    p = get_team_profile(t)\n",
    "    print(f\"{t:20s} | att={p['attack']:.3f} def={p['defense']:.3f} n={p['n']}\")\n",
    "\n",
    "print(f'\\n✅ League avg goals/team/match: {LEAGUE_AVG_GOALS:.3f}')"
   ]
