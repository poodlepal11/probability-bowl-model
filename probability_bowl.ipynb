    "HOME_ML = +165\n",
    "DRAW_ML = +120\n",
    "AWAY_ML = +175\n",
    "\n",
    "# Market O/U line → use as avg_goals proxy\n",
    "# O/U 1.5 → 1.8 | O/U 2.0 → 2.1 | O/U 2.5 → 2.4 | O/U 3.0 → 2.9\n",
    "AVG_GOALS = 1.8   # O/U is 1.5 → very low scoring expected\n",
    "\n",
    "# Referee: look up on Transfermarkt\n",
    "# total yellows per game / 2 = per-team rate\n",
    "# Turpin: 3.39/game → 1.7 per team\n",
    "CARDS_HOME = 1.5   # slightly lower — disciplined game script\n",
    "CARDS_AWAY = 1.5\n",
    "\n",
    "# Corners: adjust for territorial dominance\n",
    "# Paraguay avg only 0.5 corners/game in this WC (!!)\n",
    "CORNERS_HOME = 2.5\n",
    "CORNERS_AWAY = 4.5   # Australia attack-minded per confirmed XI\n",
    "\n",
    "# Offsides: higher for chasing teams / high defensive lines\n",
    "OFFSIDES_HOME = 1.4  # Paraguay conservative\n",
    "OFFSIDES_AWAY = 1.9  # Australia running in behind\n",
    "\n",
    "# SOT rates (proxy for shot quality)\n",
    "SHOTS_HOME = 3.5\n",
    "SHOTS_AWAY = 4.5\n",
    "\n",
    "# Context notes (for your own reference)\n",
    "NOTES = \"\"\"\n",
    "- Almiron SUSPENDED → Enciso is sole creator + penalty taker\n",
    "- Australia confirmed aggressive XI (Popovic not parking)\n",
    "- Referee Turpin: 3.39 yellows/game (moderate)\n",
    "- Paraguay avg 0.5 corners/game in this tournament\n",
    "- Market O/U 1.5 (very cagey)\n",
    "- Both teams CAN advance with a draw\n",
    "\"\"\"\n",
    "\n",
    "# ── RUN ───────────────────────────────────────────────────────────────────────\n",
    "print(f'\\n{\"=\"*60}')\n",
    "print(f'  {HOME} vs {AWAY}')\n",
    "print(f'{\"=\"*60}')\n",
    "print(NOTES)\n",
    "\n",
    "# Show team profiles from historical data\n",
