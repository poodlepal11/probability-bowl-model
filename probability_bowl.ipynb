    "# ── CELL 4: Core model functions ───────────────────────────────────────────────\n",
    "\n",
    "# --- Market odds → fair probabilities ---\n",
    "def american_to_implied(odds: int) -> float:\n",
    "    return 100/(odds+100) if odds > 0 else abs(odds)/(abs(odds)+100)\n",
    "\n",
    "def remove_vig(home_odds: int, draw_odds: int, away_odds: int) -> dict:\n",
    "    raw = {k: american_to_implied(v) for k, v in\n",
    "           zip(['home','draw','away'], [home_odds, draw_odds, away_odds])}\n",
    "    total = sum(raw.values())\n",
    "    fair  = {k: v/total for k, v in raw.items()}\n",
    "    print(f'  Vig removed: {(total-1)*100:.1f}% | '\n",
    "          f'Home {fair[\"home\"]:.1%} Draw {fair[\"draw\"]:.1%} Away {fair[\"away\"]:.1%}')\n",
    "    return fair\n",
    "\n",
    "# --- Dixon-Coles correction ---\n",
    "def tau(x, y, lam, mu, rho):\n",
    "    if   x==0 and y==0: return 1 - lam*mu*rho\n",
    "    elif x==0 and y==1: return 1 + lam*rho\n",
    "    elif x==1 and y==0: return 1 + mu*rho\n",
    "    elif x==1 and y==1: return 1 - rho\n",
    "    return 1.0\n",
    "\n",
    "def dc_matrix(lam, mu, max_g=8, rho=-0.13):\n",
    "    M = np.array([[tau(i,j,lam,mu,rho)*poisson.pmf(i,lam)*poisson.pmf(j,mu)\n",
    "                   for j in range(max_g)] for i in range(max_g)])\n",
    "    return M / M.sum()\n",
    "\n",
    "# --- λ estimation: blend market odds + historical rates ---\n",
    "def estimate_lambdas(home: str, away: str,\n",
    "                     p_home: float, p_draw: float, p_away: float,\n",
    "                     market_weight: float = 0.65,\n",
    "                     avg_goals: float = 2.4,\n",
    "                     rho: float = -0.13) -> tuple:\n",
    "    \"\"\"\n",
    "    Blend two sources:\n",
    "      - Market odds (65% weight) — most informative prior\n",
    "      - Historical attack/defense ratings (35% weight)\n",
    "\n",
    "    market_weight=0.65 means we trust the market more than history,\n",
    "    but use history to sanity-check and adjust extreme values.\n",
    "    \"\"\"\n",
    "    # --- Market-implied λ (via optimization) ---\n",
    "    def obj_market(params):\n",
    "        lam, mu = params\n",
    "        if lam <= 0 or mu <= 0: return 1e6\n",
    "        M = dc_matrix(lam, mu, rho=rho)\n",
    "        ph = np.tril(M, -1).sum()  # home win\n",
    "        pd_ = np.diag(M).sum()     # draw\n",
    "        pa = np.triu(M,  1).sum()  # away win\n",
    "        return (ph-p_home)**2 + (pd_-p_draw)**2 + (pa-p_away)**2\n",
    "\n",
    "    ratio = (p_home + 0.5*p_draw) / (p_away + 0.5*p_draw + 1e-6)\n",
    "    lam0  = avg_goals * ratio / (1 + ratio)\n",
    "    mu0   = avg_goals - lam0\n",
    "    res   = minimize(obj_market, [lam0, mu0],\n",
    "                     bounds=[(0.1,5),(0.1,5)], method='L-BFGS-B')\n",
    "    lam_mkt, mu_mkt = res.x\n",
    "\n",
    "    # --- Historical λ ---\n",
    "    hp = get_team_profile(home)\n",
    "    ap = get_team_profile(away)\n",
    "    # Dixon-Coles style: lam = attack_home * defense_away * league_avg\n",
    "    lam_hist = hp['attack'] * ap['defense'] * LEAGUE_AVG_GOALS\n",
    "    mu_hist  = ap['attack'] * hp['defense'] * LEAGUE_AVG_GOALS\n",
    "\n",
    "    # Use historical data only if we have enough matches\n",
    "    hist_weight = (1 - market_weight) if (hp['n'] >= 5 and ap['n'] >= 5) else 0.0\n",
    "    mkt_weight  = 1 - hist_weight\n",
    "\n",
    "    lam = mkt_weight * lam_mkt + hist_weight * lam_hist\n",
    "    mu  = mkt_weight * mu_mkt  + hist_weight * mu_hist\n",
    "\n",
    "    print(f'  Market λ: home={lam_mkt:.3f} away={mu_mkt:.3f}')\n",
    "    if hist_weight > 0:\n",
    "        print(f'  History λ: home={lam_hist:.3f} away={mu_hist:.3f} '\n",
    "              f'(home n={hp[\"n\"]}, away n={ap[\"n\"]})')\n",
    "    print(f'  Blended λ: home={lam:.3f} away={mu:.3f} '\n",
    "          f'(market {mkt_weight:.0%} / history {hist_weight:.0%})')\n",
    "    return lam, mu\n",
    "\n",
    "print('✅ Core model functions ready.')"
   ]
